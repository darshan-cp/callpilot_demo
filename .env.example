# PostgreSQL connection string (required for API server)
DATABASE_URL=postgresql://user:password@localhost:5432/leadverify

# API server port
PORT=8080

# Frontend dev server (optional — defaults to 5173)
# PORT=5173

# Vite base path (optional — defaults to /)
# BASE_PATH=/

# API proxy target for Vite dev server (optional — defaults to http://localhost:8080)
# API_URL=http://localhost:8080

# Call provider — mock by default (no real phone calls)
ENABLE_REAL_CALLS=false

# Background campaign scheduler interval (ms)
SCHEDULER_INTERVAL_MS=60000

# Live telephony credentials (only used when ENABLE_REAL_CALLS=true)
# These are internal — never shown to end customers
TELEPHONY_API_KEY=
TELEPHONY_ASSISTANT_ID=
TELEPHONY_PHONE_NUMBER_ID=
